# WSL / Linux-first: LF in repo and working tree
* text=auto eol=lf
# Common text (optional; * already covers these)
*.md   text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.toml text eol=lf
*.sh   text eol=lf
# Binaries — no EOL conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
